{
  "junegunn/fzf",
  build = function()
    vim.fn["fzf#install"]()
  end,
},
{
  "junegunn/fzf.vim",
  config = function()
    if vim.fn.executable("rg") == 1 then
      vim.env.FZF_DEFAULT_COMMAND =
        "rg --files --hidden --follow --glob '!.git/*'"
    end
  end,
},

